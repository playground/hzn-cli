{
  "org": "$HZN_ORG_ID",
  "label": "$SERVICE_NAME for $ARCH",
  "url": "$SERVICE_NAME",
  "version": "$SERVICE_VERSION",
  "arch": "$ARCH",
  "public": true,
  "sharable": "singleton",
  "requiredServices": [],
  "userInput": [],
  "deployment": {
    "services": {
      "$SERVICE_NAME": {
        "image": "$SERVICE_CONTAINER",
        "binds": ["SHARED_VOLUME:$VOLUME_MOUNT:rw"],
        "privileged": true,
        "cap-add": "$CAP_ADD",
        "network": "$DOCKER_NETWORK_NAME"
      }
    }
  }
}
